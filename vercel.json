<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Bricks Value Hub — Pro Tool</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#07090f;--bg1:#0e1118;--bg2:#141720;--bg3:#1c2030;
  --accent:#3d8bff;--accent2:#00e0a0;--gold:#ffc840;--red:#ff3d5a;
  --text:#eef0f8;--muted:#5a6380;--soft:#9aa0b8;
  --display:'Bebas Neue',sans-serif;--body:'DM Sans',sans-serif;--mono:'DM Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--body);min-height:100vh;display:flex;flex-direction:column;}
body::before{content:'';position:fixed;inset:0;z-index:0;opacity:0.025;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  pointer-events:none;}
nav{position:relative;z-index:10;padding:16px 40px;display:flex;align-items:center;justify-content:space-between;
  background:rgba(7,9,15,0.9);border-bottom:1px solid rgba(255,255,255,0.06);}
.nav-logo{font-family:var(--display);font-size:22px;letter-spacing:0.06em;color:var(--text);text-decoration:none;}
.nav-logo span{color:var(--accent);}
.back-link{font-size:13px;color:var(--soft);text-decoration:none;}
.back-link:hover{color:var(--text);}

/* LOCK SCREEN */
#lockScreen{position:relative;z-index:1;flex:1;display:flex;align-items:center;justify-content:center;padding:40px 24px;}
.lock-box{background:var(--bg1);border:1px solid rgba(255,255,255,0.08);border-radius:20px;padding:48px 40px;max-width:420px;width:100%;text-align:center;}
.lock-icon{font-size:48px;margin-bottom:20px;}
.lock-title{font-family:var(--display);font-size:36px;letter-spacing:0.04em;margin-bottom:8px;}
.lock-sub{font-size:14px;color:var(--soft);margin-bottom:32px;line-height:1.6;font-weight:300;}
.lock-input{width:100%;background:var(--bg3);border:1px solid rgba(255,255,255,0.1);border-radius:10px;
  padding:13px 16px;color:var(--text);font-family:var(--mono);font-size:14px;text-align:center;
  letter-spacing:0.08em;margin-bottom:12px;}
.lock-input:focus{outline:none;border-color:var(--accent);}
.lock-btn{width:100%;background:var(--accent);color:#fff;border:none;border-radius:10px;
  padding:13px;font-family:var(--body);font-size:15px;font-weight:600;cursor:pointer;transition:opacity 0.15s;}
.lock-btn:hover{opacity:0.88;}
.lock-error{font-size:13px;color:var(--red);margin-top:10px;display:none;font-family:var(--mono);}
.lock-note{font-size:12px;color:var(--muted);margin-top:20px;font-family:var(--mono);}
.lock-note a{color:var(--accent);text-decoration:none;}

/* PRO TOOL WRAPPER */
#proContent{display:none;flex:1;flex-direction:column;}
#proFrame{flex:1;border:none;width:100%;min-height:calc(100vh - 57px);}
</style>
</head>
<body>

<nav>
  <a href="/" class="nav-logo">🧱 Bricks <span>Value</span> Hub</a>
  <a href="/" class="back-link">← Back to home</a>
</nav>

<div id="lockScreen">
  <div class="lock-box">
    <div class="lock-icon">🔐</div>
    <div class="lock-title">PRO ACCESS</div>
    <div class="lock-sub">This area is for subscribers only. Enter the password you received in your Discord support ticket.</div>
    <input class="lock-input" type="password" id="passInput" placeholder="Enter password" onkeydown="if(event.key==='Enter')checkPass()"/>
    <button class="lock-btn" onclick="checkPass()">Unlock Pro Tool →</button>
    <div class="lock-error" id="lockError">Incorrect password. Check your Discord ticket.</div>
    <div class="lock-note">Not a subscriber? <a href="https://discord.gg/YOURLINK">Open a support ticket</a> to get access.</div>
  </div>
</div>

<div id="proContent">
  <iframe id="proFrame" src=""></iframe>
</div>

<script>
// Change this password whenever you want — just update everyone in Discord
const PASSWORD = 'bvh2024pro';

function checkPass() {
  const input = document.getElementById('passInput').value.trim();
  const error = document.getElementById('lockError');
  if (input === PASSWORD) {
    document.getElementById('lockScreen').style.display = 'none';
    const content = document.getElementById('proContent');
    content.style.display = 'flex';
    // Load the pro tool inline
    fetch('BricksValueHub_Pro.html')
      .then(r => r.text())
      .then(html => {
        const frame = document.getElementById('proFrame');
        frame.srcdoc = html;
      })
      .catch(() => {
        content.innerHTML = '<p style="padding:40px;color:#ff3d5a;font-family:monospace;">Error loading Pro tool. Contact support.</p>';
      });
    error.style.display = 'none';
  } else {
    error.style.display = 'block';
    document.getElementById('passInput').value = '';
  }
}
</script>
</body>
</html>
